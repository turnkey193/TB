# ===== Supabase =====
# 從 Supabase Dashboard > Settings > API 取得
SUPABASE_URL=https://obgobetnlecbmypvfnsq.supabase.co
SUPABASE_KEY=              # anon key
SUPABASE_SERVICE_KEY=      # service role key（伺服器端使用，不可外洩）

# ===== 登入 / Session =====
JWT_SECRET=                # Phase 1 若導入 JWT 會用到，先保留欄位

# ===== 執行環境 =====
NODE_ENV=development       # development | production
PORT=3001                  # server.js 監聽埠（預設 3001）

# ===== Google Sheets / Drive =====
# Service account JSON 檔路徑（相對於專案根）
GOOGLE_SERVICE_ACCOUNT_KEY=huaaibot-key.json
